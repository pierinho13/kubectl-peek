Output assets/kubectl-peek-events-inspection.gif

Set Shell "zsh"
Set FontSize 22
Set Width 1400
Set Height 760
Set TypingSpeed 45ms
Set Theme "Dracula"

# Browse Warning events ordered by latest occurrence.
Type "kubectl-peek events --warnings"
Enter
Sleep 1000ms
# Open details for the first event.
Enter
Sleep 1800ms

Type "clear"
Enter
Type "kubectl-peek events --browse"
Enter
Sleep 1s
Down
Enter
Sleep 1s
Enter
Sleep 1s
Enter
Sleep 3s
