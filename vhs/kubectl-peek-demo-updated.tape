Output assets/kubectl-peek-demo.gif

Set Shell "zsh"
Set FontSize 22
Set Width 1200
Set Height 700
Set TypingSpeed 60ms
Set Theme "Dracula"

# First run: built-in Secret discovery
Type "kubectl-peek secret -n monitoring"
Enter
Sleep 2s
Down
Down
Down
Down
Down
Down
Sleep 500ms
Type "/"
Sleep 500ms
Type "dex"
Enter
Sleep 300ms

ScrollUp@250ms 100
Sleep 2s
